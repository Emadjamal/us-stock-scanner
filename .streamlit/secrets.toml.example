# For local testing of cloud features.
# On Streamlit Community Cloud, go to the app settings → Secrets and paste the real values.

# === Turso / libSQL for persistent DB on cloud (recommended) ===
# TURSO_DATABASE_URL = "libsql://your-db.turso.io"
# TURSO_AUTH_TOKEN = "eyJ..."

# === Telegram Bot (for the bot.py publishing option) ===
# TELEGRAM_BOT_TOKEN = "123456789:AAF-YourBotTokenFromBotFather"

# Example if we switch to Google Sheets for persistence later:
# [gcp_service_account]
# ... (same as before)

# You can also set DEFAULT_MODE=swing for the bot process.
